# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Comet ML Configuration
# Get your API key from: https://www.comet.com/
COMET_API_KEY=your_comet_api_key_here
COMET_PROJECT_NAME=your_project_name
COMET_WORKSPACE=your_comet_workspace

# Opik Configuration (LLM Observability)
# Get your API key from: https://www.comet.com/
OPIK_API_KEY=your_opik_api_key_here
OPIK_PROJECT_NAME=agno-blog-llm-tracing
OPIK_WORKSPACE=your_opik_workspace
